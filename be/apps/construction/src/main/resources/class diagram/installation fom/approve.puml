@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam shadowing false

skinparam class {
    BackgroundColor White
    BorderColor #263238
    ArrowColor #263238
}

package "Construction Service" #FFE0B2 {
    package "Adapter" {
        class InstallationFormController {
            + approveInstallationForm(request: ApproveRequest): ResponseEntity<WrapperApiResponse>
        }
    }

    package "Application" {
        class InstallationFormHandlingUseCase {
            - ifSrv: InstallationFormService
            - costEstimateUseCase: CostEstimateUseCase
            + approveInstallationForm(request: ApproveRequest): void
        }

        interface InstallationFormService {
            + approveAndAssignInstallationForm(request: ApproveRequest): void
            + getByFormCodeAndFormNumber(formCode: String, formNumber: String): InstallationFormListResponse
        }

        class InstallationFormServiceImpl {
            - ifRepo: InstallationFormRepository
            - empSrv: EmployeeService
            + approveAndAssignInstallationForm(request: ApproveRequest): void
        }

        class CostEstimateUseCase {
            - estSrv: CostEstimateService
            - messageProducer: MessageProducer
            + createEstimate(request: CreateRequest): CostEstimateResponse
        }

        interface CostEstimateService {
            + createEstimate(request: CreateRequest): CostEstimateResponse
        }

        class CostEstimateServiceImpl {
            - estRepo: CostEstimateRepository
            + createEstimate(request: CreateRequest): CostEstimateResponse
        }

        class ApproveRequest <<record>> {
            + empId: String
            + formNumber: String
            + formCode: String
            + status: Boolean
        }

        class CreateRequest <<record>> {
            + customerName: String
            + address: String
            + registrationAt: LocalDate
            + createBy: String
            + formCode: String
            + formNumber: String
        }

        class CreatedEvent <<record>> {
            + customerName: String
            + formCode: String
            + formNumber: String
            + surveyStaffName: String
        }
    }

    package "Domain" {
        class InstallationForm <<Entity>> {
            - id: InstallationFormId
            - status: FormProcessingStatus
            + setStatus(status: FormProcessingStatus): void
        }

        class CostEstimate <<Entity>> {
            - estimationId: String
            - customerName: String
            - installationForm: InstallationForm
        }
    }

    package "Infrastructure" {
        interface InstallationFormRepository <<Repository>>
        interface CostEstimateRepository <<Repository>>
        
        class MessageProducer {
            + send(routingKey: String, data: Object): void
        }

        interface EmployeeService <<FeignClient>> {
            + isEmployeeExisting(id: String): WrapperApiResponse
        }
    }
}

package "Notification Service" #C8E6C9 {
    package "Event Consumer" {
        abstract class GeneralEventConsumer<T> {
            # messagingTemplate: SimpMessagingTemplate
            # handle(event: T, topics: List<String>, title: String, link: String): void
            {abstract} # buildMessage(event: T): String
        }

        class CreateEstimateConsumer {
            + handle(event: CreateEventMessage): void
        }

        abstract class BaseEventMessage {
            + pattern: String
            + data: EstData
        }

        class CreateEventMessage extends BaseEventMessage

        class EstData <<record>> {
            + customerName: String
            + formCode: String
            + formNumber: String
            + surveyStaffName: String
        }
    }

    package "Infrastructure" as NotifyInfra {
        class SimpMessagingTemplate <<Shared>>
        enum Topic <<enumeration>>
    }
}

' Relationships
InstallationFormController o-- InstallationFormHandlingUseCase
InstallationFormController ..> ApproveRequest

InstallationFormHandlingUseCase o-- InstallationFormService
InstallationFormHandlingUseCase o-- CostEstimateUseCase
InstallationFormHandlingUseCase ..> ApproveRequest
InstallationFormHandlingUseCase ..> CreateRequest

InstallationFormService <|.. InstallationFormServiceImpl
InstallationFormServiceImpl o-- InstallationFormRepository
InstallationFormServiceImpl o-- EmployeeService
InstallationFormServiceImpl ..> InstallationForm

CostEstimateUseCase o-- CostEstimateService
CostEstimateUseCase o-- MessageProducer
CostEstimateUseCase ..> CreateRequest
CostEstimateUseCase ..> CreatedEvent

CostEstimateService <|.. CostEstimateServiceImpl
CostEstimateServiceImpl o-- CostEstimateRepository
CostEstimateServiceImpl ..> CostEstimate

CostEstimate "1" o-- "1" InstallationForm

' Event Flow
MessageProducer ..> CreateEstimateConsumer : "RabbitMQ [CreatedEvent]"
CreateEstimateConsumer --|> GeneralEventConsumer
CreateEstimateConsumer ..> CreateEventMessage
CreateEventMessage ..> EstData
GeneralEventConsumer o-- SimpMessagingTemplate
SimpMessagingTemplate ..> Topic

@enduml