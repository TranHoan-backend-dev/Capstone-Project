@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam shadowing false

skinparam class {
    BackgroundColor White
    BorderColor #263238
    ArrowColor #263238
}

package "Construction Service" #FFE0B2 {
    package "Adapter" {
        class InstallationFormController {
            + assignInstallationForm(request: InstallationFormId, empId: String): ResponseEntity<WrapperApiResponse>
        }
    }

    package "Application" {
        class InstallationFormHandlingUseCase {
            - ifSrv: InstallationFormService
            - messageProducer: MessageProducer
            - empSrv: EmployeeService
            + assignInstallationFormToSurveyStaff(id: InstallationFormId, empId: String): void
        }

        interface InstallationFormService {
            + assignInstallationForm(id: String, installationFormId: InstallationFormId, status: Boolean): void
            + getByFormCodeAndFormNumber(formCode: String, formNumber: String): InstallationFormListResponse
        }

        class InstallationFormServiceImpl {
            - ifRepo: InstallationFormRepository
            - empSrv: EmployeeService
            + assignInstallationForm(id: String, installationFormId: InstallationFormId, status: Boolean): void
            + getByFormCodeAndFormNumber(formCode: String, formNumber: String): InstallationFormListResponse
        }

        class AssignEvent <<record>> {
            + formCode: String
            + formNumber: String
            + empId: String
        }
    }

    package "Domain" {
        class InstallationForm <<Entity>> {
            - id: InstallationFormId
            - customerName: String
            - address: String
            - phoneNumber: String
            - status: FormProcessingStatus
            - createdBy: String
            - handoverBy: String
            - constructedBy: String
            + setHandoverBy(value: String): void
        }

        class InstallationFormId <<Embeddable>> {
            - formCode: String
            - formNumber: String
        }

        class FormProcessingStatus <<Embeddable>> {
            - registration: ProcessingStatus
            - estimate: ProcessingStatus
            - contract: ProcessingStatus
            - construction: ProcessingStatus
        }

        enum ProcessingStatus <<enumeration>> {
            PENDING_FOR_APPROVAL
            APPROVED
            REJECTED
            PROCESSING
        }
    }

    package "Infrastructure" {
        interface InstallationFormRepository <<Repository>> {
            + findById(id: InstallationFormId): Optional<InstallationForm>
            + save(entity: InstallationForm): InstallationForm
        }

        class MessageProducer {
            - template: RabbitTemplate
            + send(routingKey: String, data: Object): void
        }

        interface EmployeeService <<FeignClient>> {
            + getRoleOfEmployeeById(id: String): WrapperApiResponse
            + getEmployeeNameById(id: String): WrapperApiResponse
        }
    }
}

package "Auth Service" #E1F5FE {
    package "Adapter" as AuthAdapter {
        class EmployeeController {
            + getRoleOfEmployeeById(id: String): WrapperApiResponse
            + getEmployeeNameById(id: String): WrapperApiResponse
        }
    }
}

' Relationships
InstallationFormController o-- InstallationFormHandlingUseCase
InstallationFormController ..> InstallationFormId

InstallationFormHandlingUseCase o-- InstallationFormService
InstallationFormHandlingUseCase o-- MessageProducer
InstallationFormHandlingUseCase o-- EmployeeService
InstallationFormHandlingUseCase ..> InstallationFormId
InstallationFormHandlingUseCase ..> AssignEvent

InstallationFormService <|.. InstallationFormServiceImpl
InstallationFormServiceImpl o-- InstallationFormRepository
InstallationFormServiceImpl o-- EmployeeService
InstallationFormServiceImpl ..> InstallationFormId

InstallationForm *-- InstallationFormId
InstallationForm *-- FormProcessingStatus
FormProcessingStatus o-- ProcessingStatus

InstallationFormRepository ..> InstallationForm
InstallationFormRepository ..> InstallationFormId

EmployeeService ..> AuthAdapter : "Feign Call"
MessageProducer ..> AssignEvent : "JSON Payload"

@enduml