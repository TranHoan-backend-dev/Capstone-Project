@startuml

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor #263238
    ArrowColor #263238
}

' ==========================================
' Construction Service
' ==========================================
package "Construction Service" #F1F8E9 {
    package "Adapter" as ConstAdapter {
        class InstallationFormController {
            + createInstallationForm(request): ResponseEntity<WrapperApiResponse>
        }
    }

    package "Application" as ConstApp {
        package "UseCase" {
            class InstallationFormHandlingUseCase {
                - ifSrv: InstallationFormService
                - messageProducer: MessageProducer
                - empSrv: EmployeeService
                + createNewInstallationRequest(request): NewInstallationFormResponse
                - getCreatorName(creatorId): String
            }
        }

        package "Service" {
            interface InstallationFormService {
                + createNewInstallationForm(request): NewInstallationFormResponse
                + isInstallationFormExisting(formNumber, formCode): boolean
            }

            class InstallationFormServiceImpl {
                - ifRepo: InstallationFormRepository
                - wsnRepo: WaterSupplyNetworkRepository
                - empSrv: EmployeeService
                - owmSrv: OverallWaterMeterService
                + createNewInstallationForm(request): NewInstallationFormResponse
                + isInstallationFormExisting(formNumber, formCode): boolean
            }
            InstallationFormService <|.. InstallationFormServiceImpl
        }

        package "DTO" as ConstDTO {
            class NewOrderRequest <<record>>
            class NewInstallationFormResponse <<record>>
        }
    }

    package "Domain" as ConstDomain {
        package "Model" {
            class InstallationForm {
                - id: InstallationFormId
                - customerName: String
                - address: String
                - phoneNumber: String
                - citizenIdentificationNumber: String
                - usageTarget: UsageTarget
                - status: FormProcessingStatus
                - network: WaterSupplyNetwork
                - createdBy: String
                - overallWaterMeterId: String
                - createdAt: LocalDateTime
                + {static} create(builder): InstallationForm
            }
            
            class WaterSupplyNetwork {
                - branchId: String
                - branchName: String
            }
        }

        package "Utility" {
            class InstallationFormId <<embeddable>> {
                - formCode: String
                - formNumber: String
            }

            class FormProcessingStatus <<value object>> {
                - registration: ProcessingStatus
                - estimate: ProcessingStatus
                - contract: ProcessingStatus
                - construction: ProcessingStatus
            }
        }
    }

    package "Infrastructure" as ConstInfra {
        interface InstallationFormRepository {
            + save(entity): InstallationForm
            + existsById_FormNumberAndId_FormCode(...): boolean
        }

        interface WaterSupplyNetworkRepository {
            + findById(id): Optional<WaterSupplyNetwork>
        }

        interface EmployeeService <<FeignClient>> {
            + isEmployeeExisting(id): WrapperApiResponse
            + getEmployeeNameById(id): WrapperApiResponse
        }

        interface OverallWaterMeterService <<FeignClient>> {
            + isOverallMeterExisting(id): WrapperApiResponse
        }

        interface MessageProducer {
            + send(routingKey, event): void
        }
    }
}

' ==========================================
' Device Service
' ==========================================
package "Device Service" #E0F2F1 {
    package "Adapter" as DeviceAdapter {
        class OverallWaterMeterController {
            - waterMeterService: WaterMeterService
            + checkOverallWaterMeterExisting(id): ResponseEntity<WrapperApiResponse>
        }
    }

    package "Application" as DeviceApp {
        package "Service" as DeviceServicePkg {
            interface WaterMeterService {
                + isOverallWaterMeterExisting(id): boolean
            }
            class WaterMeterServiceImpl {
                - overallWaterMeterRepository: OverallWaterMeterRepository
                + isOverallWaterMeterExisting(id): boolean
            }
            WaterMeterService <|.. WaterMeterServiceImpl
        }
    }

    package "Domain" as DeviceDomain {
        class OverallWaterMeter {
            - serial: String
            - name: String
            - lateralId: String
        }
    }

    package "Infrastructure" as DeviceInfra {
        interface OverallWaterMeterRepository {
            + existsById(id): boolean
        }
    }
}

' ==========================================
' Notification Service
' ==========================================
package "Notification Service" #E3F2FD {
    package "Consumer" as NotiConsumer {
        abstract class GeneralEventConsumer<T> {
            # producer: MessageProducer
            # notificationService: NotificationService
            # messagingTemplate: SimpMessagingTemplate
            # handle(event, topics, title, link)
            {abstract} # buildMessage(event): String
        }

        class CreateOrderConsumer {
            + handle(event: CreateEventMessage)
            # buildMessage(event): String
        }
        
        GeneralEventConsumer <|-- CreateOrderConsumer
    }

    package "Service" as NotiService {
        interface NotificationService {
            + createNotification(request): NotificationResponse
        }
    }

    package "DTO" as NotiDTO {
        class CreateNotificationRequest <<record>>
        class NotificationResponse <<record>> {
            + notificationId: String
            + ...
        }
    }

    package "Infrastructure" as NotiInfra {
        interface SimpMessagingTemplate {
            + convertAndSend(destination, payload): void
        }
    }
}

' ==========================================
' Auth Service
' ==========================================
package "Auth Service" #FFF3E0 {
    package "Consumer" as AuthConsumer {
        class NotificationConsumer {
            - userRepository: UserRepository
            - individualNotificationRepo: IndividualNotificationRepository
            + handle(message: NotificationCreatedEvent)
        }
    }

    package "Domain" as AuthDomain {
        class Users {
            - userId: String
            - roleName: RoleName
        }
        class IndividualNotification {
            - notificationId: String
            - userId: String
            - isRead: boolean
        }
    }

    package "Repository" as AuthRepo {
        interface UserRepository
        interface IndividualNotificationRepository
    }
}

' ==========================================
' Events
' ==========================================
package "Events" {
    class CreatedEvent <<event>> {
        + formNumber: String
        + customerName: String
        + ...
    }

    class CreateEventMessage <<event>> {
        + data: CreatedEvent
    }

    class NotificationCreatedEvent <<event>> {
        + notificationId: String
        + topics: List<String>
    }
}

' ==========================================
' Relationships
' ==========================================

' Construction Internal
InstallationFormController o--> InstallationFormHandlingUseCase
InstallationFormHandlingUseCase o--> InstallationFormService
InstallationFormHandlingUseCase o--> MessageProducer
InstallationFormHandlingUseCase o--> EmployeeService

InstallationFormServiceImpl o--> InstallationFormRepository
InstallationFormServiceImpl o--> WaterSupplyNetworkRepository
InstallationFormServiceImpl o--> EmployeeService
InstallationFormServiceImpl o--> OverallWaterMeterService

InstallationForm *-- InstallationFormId
InstallationForm *-- FormProcessingStatus
InstallationForm o-- WaterSupplyNetwork

' DTO Relationships
InstallationFormHandlingUseCase ..> NewOrderRequest : uses
InstallationFormHandlingUseCase ..> NewInstallationFormResponse : returns
InstallationFormService ..> NewOrderRequest : uses
InstallationFormService ..> NewInstallationFormResponse : returns

' Feign Client Calls
OverallWaterMeterService ..> OverallWaterMeterController : calls API

' Device Service Internal
OverallWaterMeterController o--> WaterMeterService
WaterMeterServiceImpl o--> OverallWaterMeterRepository
OverallWaterMeterRepository ..> OverallWaterMeter : manages

' Event Flows
InstallationFormHandlingUseCase ..> CreatedEvent : sends
CreateOrderConsumer ..> CreateEventMessage : consumes
CreateEventMessage *-- CreatedEvent

' Notification Service Internal & Output
GeneralEventConsumer o--> MessageProducer : uses to broadcast to Auth
GeneralEventConsumer o--> NotificationService
GeneralEventConsumer o--> SimpMessagingTemplate
GeneralEventConsumer ..> CreateNotificationRequest : creates
NotificationService ..> NotificationResponse : returns
GeneralEventConsumer ..> NotificationCreatedEvent : sends to Auth

' Auth Service Internal & Intake
NotificationConsumer ..> NotificationCreatedEvent : consumes
NotificationConsumer o-- UserRepository
NotificationConsumer o-- IndividualNotificationRepository
UserRepository ..> Users : manages
IndividualNotificationRepository ..> IndividualNotification : manages

@enduml
