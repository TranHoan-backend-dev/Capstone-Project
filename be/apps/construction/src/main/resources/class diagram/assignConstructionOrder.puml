@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor #263238
    ArrowColor #263238
}

package "Construction Service" #E3F2FD {
    package "Adapter" #F5F5F5 {
        class ConstructionController {
            + assignConstructionOrder(id: String, request: AssignRequest): ResponseEntity
        }
    }

    package "Application" #F5F5F5 {
        class ConstructionRequestUseCase {
            - constructionRequestService: ConstructionRequestService
            - ifSrv: InstallationFormService
            - messageProducer: MessageProducer
            - empSrv: EmployeeService
            + assignToConstructionCaptain(request: AssignRequest, empId: String): void
        }

        interface ConstructionRequestService {
            + createPendingRequest(employeeId: String, contractId: String, formCode: String, formNumber: String): ConstructionRequest
        }

        class ConstructionRequestServiceImpl {
            - repository: ConstructionRequestRepository
            - customerService: CustomerService
            - ifRepo: InstallationFormRepository
            - employeeService: EmployeeService
            + createPendingRequest(...)
            - validateEmployee(employeeId: String): void
        }

        interface InstallationFormService {
            + assignInstallationForm(empId: String, id: InstallationFormId, status: boolean): void
            + getByFormCodeAndFormNumber(code: String, num: String): InstallationFormListResponse
        }
    }

    package "Domain" #F5F5F5 {
        class ConstructionRequest <<Entity>> {
            - id: String
            - contractId: String
            - installationForm: InstallationForm
        }

        class InstallationForm <<Entity>> {
            - formCode: String
            - formNumber: String
            - constructedBy: String
        }

        class InstallationFormId <<ValueObject>> {
            - formCode: String
            - formNumber: String
        }

        class AssignRequest <<DTO>> {
            + formCode: String
            + formNumber: String
            + customerId: String
            + contractId: String
        }

        class AssignEvent <<Event>> {
            + formCode: String
            + formNumber: String
            + empId: String
            + status: boolean
        }
    }

    package "Infrastructure" #F5F5F5 {
        interface ConstructionRequestRepository {
            + save(request: ConstructionRequest): ConstructionRequest
        }

        interface InstallationFormRepository {
            + findById(id: InstallationFormId): Optional
            + save(form: InstallationForm): InstallationForm
        }

        interface MessageProducer {
            + send(routingKey: String, event: Object): void
        }

        interface EmployeeService <<FeignClient>> {
            + getRoleOfEmployeeById(id: String): WrapperApiResponse
        }

        interface CustomerService <<FeignClient>> {
            + checkExistenceOfContract(id: String): boolean
        }
    }
}

package "Notification Service" #E8F5E9 {
    class AssignOrderConsumer <<EventConsumer>> {
        - messagingTemplate: SimpMessagingTemplate
        + handle(event: AssignEventMessage): void
    }

    class AssignEventMessage <<DTO>> {
        + pattern: String
        + data: ApproveEventData
    }
}

package "Auth Service" #FFFDE7 {
    class AuthorizationController <<Adapter>> {
        - userService: UserService
        + getRoleOfEmployeeById(id: String): ResponseEntity
    }

    class UserService {
        + getRoleOfEmployee(id: String): Object
    }
}

' Relationships
ConstructionController o-- ConstructionRequestUseCase
ConstructionRequestUseCase o-- ConstructionRequestService
ConstructionRequestUseCase o-- InstallationFormService
ConstructionRequestUseCase o-- MessageProducer
ConstructionRequestUseCase o-- EmployeeService
ConstructionRequestService <|.. ConstructionRequestServiceImpl
ConstructionRequestServiceImpl o-- ConstructionRequestRepository
ConstructionRequestServiceImpl o-- InstallationFormRepository
ConstructionRequestServiceImpl o-- CustomerService
ConstructionRequestServiceImpl o-- EmployeeService

ConstructionRequestUseCase ..> AssignRequest : uses
ConstructionRequestUseCase ..> AssignEvent : produces
ConstructionRequestServiceImpl ..> ConstructionRequest : creates
ConstructionRequest *-- InstallationForm
InstallationForm *-- InstallationFormId

EmployeeService ..> AuthorizationController : calls (Feign)
MessageProducer ..> AssignOrderConsumer : triggers (RabbitMQ)
AssignOrderConsumer ..> AssignEventMessage : consumes

@endum
