  "receiptNumber": "BL-001",
  "customerName": "A",
  "address": "Addr",
  "paymentDate": "2024-03-19",
  "isPaid": true
}

> {%
client.test("Status is 400", function() {
  client.assert(response.status === 400);
});
%}


