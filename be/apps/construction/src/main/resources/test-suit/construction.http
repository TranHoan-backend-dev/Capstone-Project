@uri = http://localhost:9004/api/v1
@keycloak=http://localhost:8080/realms/cmsn/protocol/openid-connect
@client_secret=

### get token
POST {{keycloak}}/token
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=password&
client_id=&
client_secret={{client_secret}}&
username=&
password=&
scope=openid

> {%
 client.global.set("access_token", response.body.access_token);
 client.global.set("refresh_token", response.body.refresh_token);
%}

### L - Get Construction Orders List (đơn chờ thi công)
### 1. Happy Path - Get all construction orders (No param)
GET {{uri}}/construction/construction
Authorization: Bearer {{access_token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
client.test("Response has content", function() {
  client.assert(response.body.data != null);
});
%}

### 2. Happy Path - Pagination and Sort
GET {{uri}}/construction/construction?page=0&size=10&sort=createdAt,desc
Authorization: Bearer {{access_token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}

### 3. Happy Path - Filtering by keyword, from, and to
GET {{uri}}/construction/construction?keyword=Nguyễn&from=2024-01-01&to=2024-12-31
Authorization: Bearer {{access_token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}

### 4. Error Case - Invalid Date Format (from)
GET {{uri}}/construction/construction?from=01-01-2024
Authorization: Bearer {{access_token}}

> {%
client.test("Status is 400", function() {
  client.assert(response.status === 400);
});
%}

### 5. Error Case - Invalid Date Format (to)
GET {{uri}}/construction/construction?to=01/01/2024
Authorization: Bearer {{access_token}}

> {%
client.test("Status is 400", function() {
  client.assert(response.status === 400);
});
%}

### 6. Error Case - Unauthorized (Missing Token)
GET {{uri}}/construction/construction

> {%
client.test("Status is 401", function() {
  client.assert(response.status === 401);
});
%}

### 7. Error Case - Insufficient Permissions (403)
GET {{uri}}/construction/construction
Authorization: Bearer {{low_privilege_token}}

> {%
client.test("Status is 403", function() {
  client.assert(response.status === 403);
});
%}

### 8. Happy Path - Pagination (page 1, size 5)
GET {{uri}}/construction/construction?page=1&size=5
Authorization: Bearer {{access_token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}

