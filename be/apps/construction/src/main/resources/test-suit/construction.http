### Variables
@baseUrl = http://localhost:9004/api/v1
@token = {{access_token}}

### TC01 - Giao đơn thi công thành công (Happy Path)
PATCH {{baseUrl}}/construction/eae87df0-7f02-47b9-baa2-ac2bc9ea61fb
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "formCode": "c2eebc99-9c0b-4ef8-bb6d-6bb9bd380a13",
  "formNumber": "FORM-2024-0003",
  "contractId": "adsfasdvaerg"
}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}


### TC02 - Giao thi công cho nhân viên sai vai trò (400)
PATCH {{baseUrl}}/construction/EMP-IT-001
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "formCode": "LĐN",
  "formNumber": "2024/001",
  "contractId": "CONT-001"
}

> {%
client.test("Status is 400", function() {
  client.assert(response.status === 400);
});
%}


### TC03 - Thiếu trường bắt buộc formCode (400)
PATCH {{baseUrl}}/construction/EMP-STF-001
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "formNumber": "2024/001",
  "customerId": "CUST-001",
  "contractId": "CONT-001"
}

> {%
client.test("Status is 400", function() {
  client.assert(response.status === 400);
});
%}


### TC04 - Mã hợp đồng không tồn tại (400)
PATCH {{baseUrl}}/construction/EMP-STF-001
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "formCode": "LĐN",
  "formNumber": "2024/001",
  "customerId": "CUST-001",
  "contractId": "NON-EXISTENT"
}

> {%
client.test("Status is 400", function() {
  client.assert(response.status === 400);
});
%}


### TC05 - Cập nhật nhân viên cho đơn chờ thi công thành công (200)
PATCH {{baseUrl}}/construction/pending-requests/REQ-001/EMP-STF-002
Authorization: Bearer {{token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}


### TC06 - Cập nhật đơn chờ với ID không tồn tại (404/400)
PATCH {{baseUrl}}/construction/pending-requests/INVALID-ID/EMP-STF-002
Authorization: Bearer {{token}}

> {%
client.test("Status is 400 or 404", function() {
  client.assert(response.status === 400 || response.status === 404);
});
%}


### TC07 - Tấn công SQL Injection vào ID nhân viên (400)
PATCH {{baseUrl}}/construction/' OR 1=1 --
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "formCode": "LĐN",
  "formNumber": "001",
  "customerId": "C1",
  "contractId": "C1"
}

> {%
client.test("Status should be error", function() {
  client.assert(response.status >= 400);
});
%}


