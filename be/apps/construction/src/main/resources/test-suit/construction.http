### 18. Happy Path - Search with no results
GET {{uri}}/construction/construction?keyword=nonexistentkeyword123
Authorization: Bearer {{access_token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
client.test("Response has empty data", function() {
  client.assert(response.body.data.content.length === 0);
});
%}
