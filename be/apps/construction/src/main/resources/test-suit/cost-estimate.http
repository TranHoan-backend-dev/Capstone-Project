@uri = http://localhost:9004/api/v1/estimates
@keycloak=http://localhost:8080/realms/cmsn/protocol/openid-connect
@client_secret=

### get token
POST {{keycloak}}/token
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=password&
client_id= &
client_secret={{client_secret}}&
username= &
password= &
scope=openid

> {%
  client.global.set("access_token", response.body.access_token);
  client.global.set("refresh_token", response.body.refresh_token);
%}

### Get all estimates - Happy case (default)
GET {{uri}}
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - With pagination
GET {{uri}}?page=0&size=10
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - With sorting
GET {{uri}}?sort=id,desc
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Filter by keyword
GET {{uri}}?keyword=Test
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Filter by date range (from-to)
GET {{uri}}?from=01-01-2023&to=31-12-2023
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Filter by keyword and pagination
GET {{uri}}?keyword=Project&page=0&size=5&sort=customerName,asc
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Empty keyword
GET {{uri}}?keyword=
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Invalid date format (Should return 400 due to @Pattern)
GET {{uri}}?from=2023-01-01
Authorization: Bearer {{access_token}}
Accept: application/json

### Get estimate by ID
GET {{uri}}/{{estimate_id}}
Authorization: Bearer {{access_token}}
Accept: application/json

### C - Create estimate (Validation Failure - missing required fields)
POST {{uri}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
 "customerName": "",
 "address": "",
 "formCode": "CODE-01"
}

### C - Create estimate
POST {{uri}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
 "customerName": "Trần Văn A",
 "address": "123 Đường ABC, Phường X, Quận Y",
 "note": "Khách hàng yêu cầu lắp nhanh",
 "contractFee": 2000000,
 "surveyFee": 100000,
 "surveyEffort": 1,
 "installationFee": 1500000,
 "laborCoefficient": 20,
 "generalCostCoefficient": 5,
 "precalculatedTaxCoefficient": 10,
 "constructionMachineryCoefficient": 0,
 "vatCoefficient": 10,
 "designCoefficient": 2,
 "designFee": 500000,
 "designImageUrl": "http://storage.com/design.png",
 "registrationAt": "2023-10-27",
 "createBy": "6e9f757b-6fa1-4aa6-b7cb-a4cf2290eb20",
 "waterMeterSerial": "SN12345678",
 "overallWaterMeterId": "METER-001",
 "formNumber": "7dfebc99-9c0b-4ef8-bb6d-6bb9bd380a2e",
 "formCode": "FORM-2024-0030"
}

###
@estimate_id = 65eace3c-fcb5-45e5-8a4b-cfaed3164bc0

### U - Update estimate (Happy Case - Finish)
PUT {{uri}}/{{estimate_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "generalInformation": {
    "note": "Lưu bản nháp"
  },
  "material": [],
  "isFinished": false
}

### U - Update estimate (Not found)
PUT {{uri}}/invalid-id
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "generalInformation": {
    "customerName": "Test"
  },
  "material": [],
  "isFinished": false
}

### U - Validation failure (missing isFinished)
PUT {{uri}}/{{estimate_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "generalInformation": {
    "customerName": "Trần Văn A"
  }
}

### P - Approve estimate
PATCH {{uri}}/{{estimate_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

true

### P - Reject estimate
PATCH {{uri}}/{{estimate_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

false

### P - Approve estimate (Not found)
PATCH {{uri}}/invalid-id
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

true

### View reports of requests pending cost estimates
GET http://localhost:9004/api/v1/installation-forms/estimate/pending?page=0&size=10
Authorization: Bearer {{access_token}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}

