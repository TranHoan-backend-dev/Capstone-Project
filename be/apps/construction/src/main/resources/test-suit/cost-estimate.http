@uri = http://localhost:9004/api/v1/estimates
@keycloak=http://localhost:8080/realms/cmsn/protocol/openid-connect
@client_secret=

### get token
POST {{keycloak}}/token
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=password&
client_id=&
client_secret={{client_secret}}&
username=&
password=&
scope=openid

> {%
  client.global.set("access_token", response.body.access_token);
  client.global.set("refresh_token", response.body.refresh_token);
%}

### Get all estimates - Happy case (default)
GET {{uri}}
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - With pagination
GET {{uri}}?page=0&size=10
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - With sorting
GET {{uri}}?sort=id,desc
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Filter by keyword
GET {{uri}}?keyword=Test
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Filter by date range (from-to)
# Note: Based on @Pattern(regexp = "dd-MM-yyyy") in BaseFilterRequest
GET {{uri}}?from=01-01-2023&to=31-12-2023
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Filter by keyword and pagination
GET {{uri}}?keyword=Project&page=0&size=5&sort=customerName,asc
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Empty keyword
GET {{uri}}?keyword=
Authorization: Bearer {{access_token}}
Accept: application/json

### Get all estimates - Invalid date format (Should return 400 due to @Pattern)
GET {{uri}}?from=2023-01-01
Authorization: Bearer {{access_token}}
Accept: application/json

### C - Create estimate
POST {{uri}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "customerName": "Trần Văn A",
  "address": "123 Đường ABC, Phường X, Quận Y",
  "note": "Khách hàng yêu cầu lắp nhanh",
  "contractFee": 2000000,
  "surveyFee": 100000,
  "surveyEffort": 1,
  "installationFee": 1500000,
  "laborCoefficient": 20,
  "generalCostCoefficient": 5,
  "precalculatedTaxCoefficient": 10,
  "constructionMachineryCoefficient": 0,
  "vatCoefficient": 10,
  "designCoefficient": 2,
  "designFee": 500000,
  "designImageUrl": "http://storage.com/design.png",
  "status": "PROCESSING",
  "registrationAt": "2023-10-27",
  "createBy": "user-123",
  "waterMeterSerial": "SN12345678",
  "overallWaterMeterId": "METER-001",
  "formCode": "CODE-01",
  "formNumber": "NUM-001"
}

> {%
  client.global.set("estimate_id", response.body.data.id);
%}

### R - Get estimate by ID
GET {{uri}}/{{estimate_id}}
Authorization: Bearer {{access_token}}
Accept: application/json

### R - Get estimate by ID (Not found)
GET {{uri}}/invalid-id
Authorization: Bearer {{access_token}}
Accept: application/json

### U - Update estimate
PUT {{uri}}/{{estimate_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "customerName": "Trần Văn A Updated",
  "address": "456 Đường XYZ, Phường X, Quận Y",
  "note": "Cập nhật ghi chú",
  "contractFee": 2500000,
  "surveyFee": 120000,
  "surveyEffort": 2,
  "installationFee": 1800000,
  "laborCoefficient": 25,
  "generalCostCoefficient": 6,
  "precalculatedTaxCoefficient": 10,
  "constructionMachineryCoefficient": 5,
  "vatCoefficient": 10,
  "designCoefficient": 3,
  "designFee": 600000,
  "designImageUrl": "http://storage.com/design_updated.png",
  "status": "COMPLETED",
  "registrationAt": "2023-10-28",
  "createBy": "user-123",
  "waterMeterSerial": "SN12345678",
  "overallWaterMeterId": "METER-001",
  "formCode": "CODE-01",
  "formNumber": "NUM-001"
}

### U - Update estimate (Not found)
PUT {{uri}}/invalid-id
Content-Type: application/json
Authorization: Bearer {{access_token}}
Accept: application/json

{
  "customerName": "Test",
  "address": "Test",
  "contractFee": 0,
