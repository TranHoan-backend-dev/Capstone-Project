### TC10 - SQL Injection attempt in serial
POST http://localhost:9006/api/v1/usage/' OR 1=1 --
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="index"

125.5
--WebAppBoundary
Content-Disposition: form-data; name="recordingDate"

2024-03-27
--WebAppBoundary
Content-Disposition: form-data; name="image"; filename="img.png"
Content-Type: image/png

< ./img.png
--WebAppBoundary--

> {%
client.test("Status is 400 or 404", function() {
  client.assert(response.status === 400 || response.status === 404);
});
%}


