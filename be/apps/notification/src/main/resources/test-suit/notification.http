### TC08 - Get notifications successfully
GET http://localhost:9007/api/v1/notification?page=0&size=10
Authorization: Bearer {{jwt}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}


### TC09 - Get notifications without authentication
GET http://localhost:9007/api/v1/notification?page=0&size=10

> {%
client.test("Status is 401", function() {
  client.assert(response.status === 401);
});
%}


### TC10 - Get notifications with invalid page
GET http://localhost:9007/api/v1/notification?page=-1&size=10
Authorization: Bearer {{jwt}}

> {%
client.test("Status is 400 or 200 depending on config", function() {
  client.assert(response.status === 400 || response.status === 200);
});
%}


### TC11 - Get notifications with large size
GET http://localhost:9007/api/v1/notification?page=0&size=1000
Authorization: Bearer {{jwt}}

> {%
client.test("Status is 200", function() {
  client.assert(response.status === 200);
});
%}


### TC12 - Create notification with very long title
POST http://localhost:9007/api/v1/notification
Content-Type: application/json

{
  "title": "A".repeat(1000),
  "message": "Long title test",
  "link": "/test"
}

> {%
client.test("Status is 201 or 400", function() {
  client.assert(response.status === 201 || response.status === 400);
});
%}


### TC13 - Create notification with special characters
POST http://localhost:9007/api/v1/notification
Content-Type: application/json

{
  "title": "Special chars !@#$%^&*()_+",
  "message": "Testing special chars in message \n \t \" '",
  "link": "/test?param=value"
}

> {%
client.test("Status is 201", function() {
  client.assert(response.status === 201);
});
%}


### TC14 - Create notification with HTML content (XSS test)
POST http://localhost:9007/api/v1/notification
Content-Type: application/json

{
  "title": "<script>alert('xss')</script>",
  "message": "<img src=x onerror=alert('xss')>",
  "link": "javascript:alert('xss')"
}

> {%
client.test("Status is 201 or 400", function() {
  client.assert(response.status === 201 || response.status === 400);
});
%}


### TC15 - Get notifications with invalid sort parameter
GET http://localhost:9007/api/v1/notification?sort=invalidField,asc
Authorization: Bearer {{jwt}}

> {%
client.test("Status is 500 or 200 with default sort", function() {
  client.assert(response.status === 500 || response.status === 200);
});
%}
