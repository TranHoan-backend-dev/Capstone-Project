### TC01 - Create notification successfully
POST http://localhost:9007/api/v1/notification
Content-Type: application/json

{
  "title": "Welcome",
  "message": "Welcome to the system",
  "link": "/dashboard"
}

> {%
client.test("Status is 201", function() {
  client.assert(response.status === 201);
});
%}


### TC02 - Create notification with missing title (Optional)
POST http://localhost:9007/api/v1/notification
Content-Type: application/json

{
  "message": "System Update",
  "link": "/updates"
}

> {%
client.test("Status is 201", function() {
  client.assert(response.status === 201);
});
%}


### TC03 - Create notification with missing message (Required - @NotBlank)
POST http://localhost:9007/api/v1/notification
Content-Type: application/json

{
  "title": "Alert",
  "link": "/alert"
}

> {%
client.test("Status is 400", function() {
  client.assert(response.status === 400);
});
%}


