### TC01 - Create notification successfully (IT_STAFF)
POST http://localhost:9007/api/v1/notification
Content-Type: application/json
Authorization: Bearer {{it_staff_token}}

{
  "title": "Bảo trì hệ thống định kỳ",
  "message": "Hệ thống sẽ tạm ngưng hoạt động từ 00:00 đến 02:00 ngày 25/03/2026 để nâng cấp.",
  "link": "/news/maintenance-2026-03"
}

> {%
client.test("Status is 201", function() {
  client.assert(response.status === 201);
});
%}


### TC02 - Create notification without Authorization
POST http://localhost:9007/api/v1/notification
Content-Type: application/json

{
  "title": "Unauthorized Test",
  "message": "Should fail",
  "link": "/test"
}

> {%
client.test("Status is 401 or 403", function() {
  client.assert(response.status === 401 || response.status === 403);
});
%}


### TC03 - Create notification with invalid role (e.g. USER)
POST http://localhost:9007/api/v1/notification
Content-Type: application/json
Authorization: Bearer {{user_token}}

{
  "title": "Forbidden Test",
  "message": "Should fail",
  "link": "/test"
}

> {%
client.test("Status is 403", function() {
  client.assert(response.status === 403);
});
%}


