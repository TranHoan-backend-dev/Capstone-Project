### TC13 - SQL Injection attempt in title
POST http://localhost:9007/api/v1/notification
Content-Type: application/json
Authorization: Bearer {{it_staff_token}}

{
  "title": "Test' OR '1'='1",
  "message": "SQL Injection attempt",
  "link": "/test"
}

> {%
client.test("Status is 400 or 201", function() {
  client.assert(response.status === 400 || response.status === 201);
});
%}


### TC14 - Very long title
POST http://localhost:9007/api/v1/notification
Content-Type: application/json
Authorization: Bearer {{it_staff_token}}

{
  "title": "A".repeat(1000),
  "message": "Long title message",
  "link": "/test"
}

> {%
client.test("Status should be handled", function() {
  client.assert(response.status === 201 || response.status === 400);
});
%}


