@keycloak=http://localhost:8080/realms/cmsn/protocol/openid-connect
@client_secret=t2io8dzbyJ9qdVdR2uoL01L6vBfViILJ
@baseUrl = http://localhost:9005/api/v1
@customersUrl = {{baseUrl}}/customers

### 0. Lấy token
# @name login
POST {{keycloak}}/token
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type = password &
client_id = cmsn &
client_secret = {{client_secret}} &
username = test &
password = 12345678 &
scope = openid

> {%
    client.global.set("access_token", response.body.access_token);
%}

### TC01 - Create customer successfully
POST {{customersUrl}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "name": "Trần Văn A",
  "email": "tranvana@example.com",
  "phoneNumber": "0901234567",
  "type": "CÁ NHÂN",
  "isBigCustomer": false,
  "usageTarget": "DOMESTIC",
  "numberOfHouseholds": 1,
  "householdRegistrationNumber": 123456,
  "protectEnvironmentFee": 1000,
  "isFree": false,
  "isSale": false,
  "m3Sale": "0",
  "fixRate": "5000",
  "installationFee": 1500000,
  "deductionPeriod": "2023-12",
  "monthlyRent": 20000,
  "waterMeterType": "MECHANICAL",
  "citizenIdentificationNumber": "012345678901",
  "citizenIdentificationProvideAt": "Cục CSQLHC về TTXH",
  "paymentMethod": "CASH",
  "bankAccountNumber": "123456789",
  "bankAccountProviderLocation": "Vietcombank",
  "bankAccountName": "TRAN VAN A",
  "budgetRelationshipCode": "BRC001",
  "passportCode": "P001",
  "connectionPoint": "CP001",
  "isActive": true,
  "formNumber": "IF_001",
  "formCode": "IF_TEST_001",
  "waterPriceId": "WP_TEST_001",
  "waterMeterId": "WM_TEST_001"
}

> {%
client.test("Status is 201", function() {
  client.assert(response.status === 201);
});
client.global.set("customer_id", response.body.data.customerId);
%}

