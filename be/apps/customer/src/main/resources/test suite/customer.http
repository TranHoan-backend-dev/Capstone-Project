### TC11 - SQL Injection attempt in formCode
POST {{customersUrl}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "name": "Trần Văn A",
  "email": "a@example.com",
  "phoneNumber": "0901234567",
  "type": "CÁ NHÂN",
  "isBigCustomer": false,
  "usageTarget": "DOMESTIC",
  "numberOfHouseholds": 1,
  "householdRegistrationNumber": 123456,
  "protectEnvironmentFee": 1000,
  "waterMeterType": "MECHANICAL",
  "citizenIdentificationNumber": "012345678901",
  "citizenIdentificationProvideAt": "Cục CSQLHC về TTXH",
  "paymentMethod": "CASH",
  "bankAccountNumber": "123456789",
  "bankAccountProviderLocation": "Vietcombank",
  "bankAccountName": "TRAN VAN A",
  "formNumber": "IF_001",
  "formCode": "' OR 1=1 --",
  "waterPriceId": "WP_TEST_001",
  "waterMeterId": "WM_TEST_001"
}

> {%
client.test("Status is 400 or 201 depending validation", function() {
  client.assert(response.status === 400 || response.status === 201);
});
%}

### TC12 - Update customer successfully (200)
PUT {{customersUrl}}/{{customer_id}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "name": "Trần Văn A - Cập nhật",
  "email": "tranvana.updated@example.com",
  "phoneNumber": "0987654321",
  "type": "DOANH NGHIỆP",
  "isBigCustomer": true,
  "usageTarget": "INDUSTRIAL",
  "numberOfHouseholds": 2,
  "householdRegistrationNumber": 654321,
  "protectEnvironmentFee": 2000,
  "isFree": false,
  "isSale": true,
  "m3Sale": "5",
  "fixRate": "10000",
  "installationFee": 2000000,
  "deductionPeriod": "2024-01",
  "monthlyRent": 30000,
  "waterMeterType": "ĐIỆN TỬ",
  "citizenIdentificationNumber": "012345678901",
  "citizenIdentificationProvideAt": "Cục CSQLHC về TTXH",
  "paymentMethod": "CHUYỂN KHOẢN",
  "bankAccountNumber": "987654321",
  "bankAccountProviderLocation": "Agribank",
  "bankAccountName": "TRAN VAN A UPDATED",
  "budgetRelationshipCode": "BRC002",
  "passportCode": "P002",
  "connectionPoint": "CP002",
  "isActive": true,
  "formNumber": "IF_001_V2",
  "formCode": "IF_TEST_001_V2",
  "waterPriceId": "WP_TEST_001",
