@keycloak = http://localhost:8080/realms/cmsn/protocol/openid-connect
@client_secret =

### username is username
POST {{keycloak}}/token
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type = password &
client_id =  &
client_secret = {{client_secret}} &
username =  &
password =  &
scope = openid

> {%
  client.global.set("access_token", response.body.access_token);
  client.global.set("refresh_token", response.body.refresh_token);
%}

### main endpoint
@uri = http://localhost:9003

### me
GET {{uri}}/api/v1/me
Authorization: Bearer {{access_token}}
Accept: application/json

### Update profile, some fields are nullable
POST {{uri}}/api/v1/me
Authorization: Bearer {{access_token}}
Content-Type: application/json
Accept: application/json

{
  "fullName": "hoan",
  "username": null,
  "phoneNumber": null,
  "birthdate": null,
  "address": null,
  "gender": null
}

### Update profile, all fields are not nullable
POST {{uri}}/api/v1/me
Authorization: Bearer {{access_token}}
Content-Type: application/json
Accept: application/json

{
  "fullName": "hoan",
  "username": "admin1",
  "phoneNumber": "1234567890",
  "birthdate": "2013-10-10",
  "address": "address",
  "gender": true
}
